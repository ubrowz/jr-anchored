#!/bin/bash
#
# generate_validate_R.zsh
# Generates validate_R_env.R from R_requirements.txt
# Run this whenever R_requirements.txt changes.
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- Project identity
PROJECT_ID_FILE="$SCRIPT_DIR/project_id.txt"
if [[ ! -f "$PROJECT_ID_FILE" ]]; then
  echo "❌ project_id.txt not found at: $PROJECT_ID_FILE"
  echo "   Contact your administrator."
  exit 1
fi
PROJECT_ID="$(tr -d '[:space:]' < "$PROJECT_ID_FILE")"

REQ_FILE="$SCRIPT_DIR/R_requirements.txt"
OUT_FILE="$SCRIPT_DIR/R/validate_R_env.R"
BASE_FILE="$SCRIPT_DIR/R_base_requirements.txt"

if [[ ! -f "$REQ_FILE" ]]; then
  echo "❌ R_requirements.txt not found at: $REQ_FILE"
  exit 1
fi

# Parse user packages (exclude comments and empty lines)
USER_PKGS=()
while IFS= read -r line || [[ -n "$line" ]]; do
  line=$(echo "$line" | tr -d '[:space:]')
  [[ -z "$line" || "$line" == \#* ]] && continue
  pkg="${line%%==*}"
  USER_PKGS+=("$pkg")
done < "$REQ_FILE"

# Base/recommended packages always validated against R version
BASE_PKGS=()
if [[ -f "$BASE_FILE" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    line=$(echo "$line" | tr -d '[:space:]')
    [[ -z "$line" || "$line" == \#* ]] && continue
    BASE_PKGS+=("$line")
  done < "$BASE_FILE"
fi

# Write the R validation script
cat > "$OUT_FILE" << 'RSCRIPT_EOF'
# =============================================================================
# validate_R_env.R
# AUTO-GENERATED — do not edit manually.
# Re-generate by running: generate_validate_R.zsh
#
# Purpose: Validates that the correct R and package versions are installed
#          from the correct validated renv library.
# Usage:   Called from validate_R_env zsh wrapper script.
# =============================================================================

ERROR_FLAG <- 0

# ---------------------------------------------------------------------------
# Locate and activate validated renv library
# ---------------------------------------------------------------------------
renv_root <- Sys.getenv("RENV_PATHS_ROOT")
if (renv_root == "") {
  stop("❌ RENV_PATHS_ROOT is not set. Run this script from the provided zsh wrapper.")
}
r_ver    <- paste0("R-", R.version$major, ".",
                   sub("\\..*", "", R.version$minor))
platform <- R.version$platform
platform_dir <- Sys.getenv("JR_R_PLATFORM_DIR", unset = "macos")
lib_path <- file.path(renv_root, "renv", "library", platform_dir, r_ver, platform)
if (!dir.exists(lib_path)) {
  stop(paste("❌ renv library not found at:", lib_path))
}
.libPaths(c(lib_path, .libPaths()))

# ---------------------------------------------------------------------------
# R version
# ---------------------------------------------------------------------------
r_ver_short <- paste(R.version$major,
                     sub("\\..*", "", R.version$minor), sep = ".")
message("")
message("=============================================================")
message(" R Environment Validation Report")
message(paste(" Generated:", Sys.time()))
message("=============================================================")
message("")
message(paste("R version  :", r_ver_short))
message(paste("Library    :", lib_path))
message("")

RSCRIPT_EOF

# Append base packages block
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo "# Base / recommended packages (version guaranteed by R version pin)" >> "$OUT_FILE"
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo "message(\"Base R packages:\")" >> "$OUT_FILE"
for pkg in "${BASE_PKGS[@]}"; do
  cat >> "$OUT_FILE" << EOF
tryCatch({
  ver  <- as.character(packageVersion("$pkg"))
  path <- find.package("$pkg")
  message(paste("  ✅ $pkg", ver, "from", path))
}, error = function(e) {
  message("  ❌ $pkg : NOT FOUND")
  ERROR_FLAG <<- 1
})
EOF
done

echo 'message("")' >> "$OUT_FILE"

# Append user packages block
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo "# User-installed packages (must come from validated renv library)" >> "$OUT_FILE"
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo "message(\"User-installed packages:\")" >> "$OUT_FILE"
for pkg in "${USER_PKGS[@]}"; do
  cat >> "$OUT_FILE" << EOF
pkg_path <- file.path(lib_path, "$pkg")
if (dir.exists(pkg_path)) {
  ver <- tryCatch(as.character(packageVersion("$pkg")), error = function(e) "UNKNOWN")
  message(paste("  ✅ $pkg", ver, "from", pkg_path))
} else {
  message(paste("  ❌ $pkg : NOT FOUND in validated library:", pkg_path))
  ERROR_FLAG <- ERROR_FLAG + 1
}
EOF
done

# Append transitive dependency inventory block
# R_requirements.txt declares only packages explicitly required by scripts.
# All other packages in the library are transitive dependencies resolved by renv.
# These are listed as informational — they do not affect the validation result.
echo "" >> "$OUT_FILE"
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo "# Transitive dependency inventory (informational — does not affect PASS/FAIL)" >> "$OUT_FILE"
echo "# ---------------------------------------------------------------------------" >> "$OUT_FILE"
echo 'message("")' >> "$OUT_FILE"
echo 'message("Transitive dependencies (renv-resolved, not directly required by scripts):")' >> "$OUT_FILE"

DECLARED_R=""
for pkg in "renv" "${BASE_PKGS[@]}" "${USER_PKGS[@]}"; do
  [[ -n "$DECLARED_R" ]] && DECLARED_R="${DECLARED_R}, "
  DECLARED_R="${DECLARED_R}\"${pkg}\""
done

cat >> "$OUT_FILE" << EOF
declared_pkgs  <- c(${DECLARED_R})
installed_dirs <- list.dirs(lib_path, recursive = FALSE, full.names = FALSE)
transitive     <- sort(setdiff(installed_dirs, declared_pkgs))
if (length(transitive) == 0) {
  message("  (none)")
} else {
  for (pkg in transitive) {
    ver <- tryCatch(as.character(packageVersion(pkg)), error = function(e) "UNKNOWN")
    message(paste("  ℹ️  ", pkg, ver))
  }
  message(paste("  Total:", length(transitive), "transitive package(s)."))
}
EOF

# Append footer
cat >> "$OUT_FILE" << 'RSCRIPT_EOF'

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
message("")
message("=============================================================")
if (ERROR_FLAG == 0) {
  message("✅ All R packages validated successfully.")
} else {
  message(paste("❌ Validation FAILED —", ERROR_FLAG, "issue(s) found."))
}
message("=============================================================")

quit(status = ERROR_FLAG)
RSCRIPT_EOF

#echo "✅ Generated: $OUT_FILE"
#echo "   Base Packages included:       ${BASE_PKGS[*]}"
#echo "   Additional Packages included: ${USER_PKGS[*]}"
