#!/bin/bash
#
# admin_scaffold_Python — create scaffold files for a new jrc_* community script
#
# Usage:
#   admin_scaffold_Python <script_basename>
#   admin_scaffold_Python --repo <module> <script_basename>
#
# Without --repo: creates files in the core wrapper/ and help/ folders.
# With --repo:    places help in repos/<module>/help/. The wrapper always
#                 goes in wrapper/. The repos/<module>/ folder structure
#                 is created if absent.
#
# Examples:
#   admin_scaffold_Python jrc_convert_txt
#   admin_scaffold_Python --repo mymodule jrc_mymodule_analysis
#
# Author: Joep Rous
# Version: 1.2

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve project root — same pattern as other admin scripts
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# --- Platform helpers
# shellcheck source=../bin/jr_platform.sh
source "$PROJECT_ROOT/bin/jr_platform.sh"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

REPO_MODULE=""

show_help() {
  echo ""
  echo "Usage: admin_scaffold_Python [--repo <module>] <script_basename>"
  echo ""
  echo "  (no flag)              Place help in help/, wrapper in wrapper/"
  echo "  --repo <module>        Place help in repos/<module>/help/."
  echo "                         Wrapper goes in wrapper/."
  echo "                         Module folder structure created if absent."
  echo ""
  echo "Examples:"
  echo "  admin_scaffold_Python jrc_convert_txt"
  echo "  admin_scaffold_Python --repo mymodule jrc_mymodule_analysis"
  echo ""
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      if [[ $# -lt 2 ]]; then
        echo "❌ --repo requires a module name argument."
        exit 1
      fi
      REPO_MODULE="$2"; shift 2 ;;
    --repo=*)
      REPO_MODULE="${1#--repo=}"; shift ;;
    -h|--help)
      show_help; exit 0 ;;
    *)
      break ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "❌ Usage: admin_scaffold_Python [--repo <module>] <script_basename>"
  echo "   Example: admin_scaffold_Python jrc_convert_txt"
  exit 1
fi

BASENAME="$1"

# ---------------------------------------------------------------------------
# Input validation
# ---------------------------------------------------------------------------

if [[ -z "$BASENAME" ]]; then
  echo "❌ Script basename must not be empty."
  exit 1
fi
if [[ "$BASENAME" =~ [/\\\ ] ]]; then
  echo "❌ Script basename must not contain spaces or path separators. Got: $BASENAME"
  exit 1
fi
if [[ -n "$REPO_MODULE" && "$REPO_MODULE" =~ [/\\\ ] ]]; then
  echo "❌ Module name must not contain spaces or path separators. Got: $REPO_MODULE"
  exit 1
fi

# Warn if name does not follow jrc_ convention
if [[ "$BASENAME" != jrc_* ]]; then
  echo "⚠️  Warning: '$BASENAME' does not follow the jrc_* naming convention."
  echo "   Community scripts should be prefixed with jrc_."
  echo "   Continuing anyway..."
  echo ""
fi

# ---------------------------------------------------------------------------
# Target paths
# ---------------------------------------------------------------------------

if [[ -n "$REPO_MODULE" ]]; then
  HELP_FILE="${PROJECT_ROOT}/repos/${REPO_MODULE}/help/${BASENAME}.txt"
else
  HELP_FILE="${PROJECT_ROOT}/help/${BASENAME}.txt"
fi
WRAPPER_FILE="${PROJECT_ROOT}/wrapper/${BASENAME}"

# ---------------------------------------------------------------------------
# Check for existing files
# ---------------------------------------------------------------------------

for target in "$WRAPPER_FILE" "$HELP_FILE"; do
  if [[ -f "$target" ]]; then
    echo "❌ File already exists: $target"
    echo "   Remove it first or choose a different basename."
    exit 1
  fi
done

# ---------------------------------------------------------------------------
# Create module folder structure if needed
# ---------------------------------------------------------------------------

if [[ -n "$REPO_MODULE" ]]; then
  mkdir -p "${PROJECT_ROOT}/repos/${REPO_MODULE}/Python"
  mkdir -p "${PROJECT_ROOT}/repos/${REPO_MODULE}/help"
  mkdir -p "${PROJECT_ROOT}/repos/${REPO_MODULE}/oq/data"
  echo "📁 Module folder: repos/${REPO_MODULE}/"
fi

# ---------------------------------------------------------------------------
# Create wrapper
# ---------------------------------------------------------------------------

printf '#!/bin/bash\nexec "$(dirname "$0")/../bin/jrrun" '"${BASENAME}"'.py "$@"\n' > "$WRAPPER_FILE"

chmod +x "$WRAPPER_FILE"

# ---------------------------------------------------------------------------
# Create help file
# ---------------------------------------------------------------------------

cat > "$HELP_FILE" << HELPFILE

Description: TODO: one or two sentence description of what this script does.

Usage: ${BASENAME} "arg1" "arg2" ...

Arguments:
	arg1        TODO: describe arg1
	arg2        TODO: describe arg2
	-h| --help  Show this help message

Example:
       ${BASENAME} "value1" "value2"
HELPFILE

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

echo ""
echo "✅ Scaffold created for: ${BASENAME}"
echo ""
if [[ -n "$REPO_MODULE" ]]; then
  echo "   wrapper/${BASENAME}  (executable)"
  echo "   repos/${REPO_MODULE}/help/${BASENAME}.txt"
  echo "   repos/${REPO_MODULE}/oq/        (empty — add OQ tests here)"
  echo "   repos/${REPO_MODULE}/oq/data/   (empty — add test data here)"
else
  echo "   wrapper/${BASENAME}  (executable)"
  echo "   help/${BASENAME}.txt"
fi
echo ""
echo "   Next steps:"
if [[ -n "$REPO_MODULE" ]]; then
  echo "   1. Create repos/${REPO_MODULE}/Python/${BASENAME}.py with the script logic"
  echo "   2. In the .py file, add after stdlib imports:"
  echo "        sys.path.insert(0, os.path.join(os.environ.get(\"JR_PROJECT_ROOT\", \"\"), \"bin\"))"
  echo "        from jr_helpers import jr_log_output_hashes"
  echo "      And call jr_log_output_hashes([out_path]) after each output file is written."
  echo "   3. Update the help file with usage and arguments"
  echo "   4. Write OQ tests in repos/${REPO_MODULE}/oq/"
  echo "   5. Add required packages to admin/python_requirements.txt if needed"
  echo "   6. Run admin_create_hash after completing the script"
else
  echo "   1. Create Python/${BASENAME}.py with the script logic"
  echo "   2. In the .py file, add after stdlib imports:"
  echo "        sys.path.insert(0, os.path.join(os.environ.get(\"JR_PROJECT_ROOT\", \"\"), \"bin\"))"
  echo "        from jr_helpers import jr_log_output_hashes"
  echo "      And call jr_log_output_hashes([out_path]) after each output file is written."
  echo "   3. Update help/${BASENAME}.txt with usage and arguments"
  echo "   4. Add ${BASENAME} to SCRIPT_IDEAS.md"
  echo "   5. Add required packages to admin/python_requirements.txt if needed"
  echo "   6. Run admin_create_hash after completing the script"
fi
echo ""
