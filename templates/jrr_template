#!/bin/zsh
set -e
#
# parameters: <par1> <par2>
#
# Copy and rename
# Modify the show_help() function with the real names and description
# Change the number in the number of argument check to the correct value
# Modify the call to the R script with the actual name (last line of template)
# Add/remove parameter variables and add/remove them from the call to the R script


# --- Script directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR" || exit 1
ADMIN_HOME="$SCRIPT_DIR/admin"

# --- R environment paths
export RENV_HOME="$HOME/.renv/jrscript"
export RENV_PATHS_ROOT="$HOME/.renv/jrscript"
export LOCAL_REPO="$SCRIPT_DIR/R_repo/my-cran-repo"

# --- Clear R library overrides before any Rscript call
unset R_LIBS
unset R_LIBS_USER
unset R_LIBS_SITE

# --- Help
show_help() {
  echo ""
  echo "Usage: jrmyscript <par1> <par2>"
  echo ""
  echo "Description:"
  echo "  blablabla"
  echo ""
  echo "Arguments:"
  echo "  par1         Description of par1"
  echo "  par2         Description of par2"
  echo "  -h|--help    Show this help message"
  echo ""
  echo "Example:"
  echo "  jrmyscript \"par1\" \"par2\""
  exit 0
}

# --- Argument handling
for arg in "$@"; do
  if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
    show_help
  fi
done
if [[ $# -eq 0 ]]; then
  show_help
fi
if [[ $# -ne 2 ]]; then
  echo "❌ Expected 2 arguments, got $#."
  echo "   Run with -h for usage."
  exit 1
fi

PAR1="$1"
PAR2="$2"

# --- Verify project integrity
if [[ ! -f "$ADMIN_HOME/project_integrity.sha256" ]]; then
  echo "❌ Integrity file missing. Contact admin."
  exit 1
fi
echo "🔎 Verifying project integrity..."
if ! shasum -a 256 -c "$ADMIN_HOME/project_integrity.sha256" >/dev/null 2>&1; then
  echo ""
  echo "❌ PROJECT INTEGRITY CHECK FAILED"
  echo "   One or more files were modified."
  echo "   Contact the administrator."
  echo ""
  exit 1
fi
echo "✅ Integrity verified"

# --- Check renv.lock exists
LOCK_FILE="$ADMIN_HOME/renv.lock"
if [[ ! -f "$LOCK_FILE" ]]; then
  echo "❌ renv.lock not found. Contact admin."
  exit 1
fi

# --- Determine if renv rebuild is needed
REQ_HASH=$(shasum "$LOCK_FILE" | cut -d' ' -f1)
HASH_FILE="$RENV_HOME/.renv_lock_hash"
RENV_LIB=$(find "$RENV_HOME/renv/library" -mindepth 3 -maxdepth 3 \
           -type d 2>/dev/null | head -1)
NEED_REBUILD=false
if [[ ! -d "$RENV_HOME" ]]; then
  NEED_REBUILD=true
elif [[ -z "$RENV_LIB" ]]; then
  NEED_REBUILD=true
elif [[ ! -f "$HASH_FILE" ]]; then
  NEED_REBUILD=true
elif [[ "$(cat "$HASH_FILE")" != "$REQ_HASH" ]]; then
  NEED_REBUILD=true
fi

# --- (Re)build renv from local repo if needed
if $NEED_REBUILD; then
  if [[ ! -d "$LOCAL_REPO" ]]; then
    echo "❌ Local R package repo not found at: $LOCAL_REPO"
    echo "   Ensure Dropbox is synced or contact admin."
    exit 1
  fi
  echo "🔄 (Re)creating R environment..."
  rm -rf "$RENV_HOME"
  mkdir -p "$RENV_HOME"
  Rscript --vanilla - <<EOF
local_repo <- paste0("file://", normalizePath("$LOCAL_REPO"))
options(repos    = c(LOCAL = local_repo),
        pkgType  = "binary",
        install.packages.compile.from.source = "never")
install.packages("renv", repos = local_repo)
Sys.setenv(RENV_PATHS_ROOT = "$RENV_HOME")
renv::init(project  = "$RENV_HOME",
           bare     = TRUE,
           restart  = FALSE)
renv::restore(project  = "$RENV_HOME",
              lockfile = "$LOCK_FILE",
              repos    = c(LOCAL = local_repo),
              prompt   = FALSE)
EOF
  echo "$REQ_HASH" > "$HASH_FILE"
fi

# --- Run log setup
LOG_FILE="$HOME/.jrscript/$PROJECT_ID/run.log"
mkdir -p "$(dirname "$LOG_FILE")"

# --- Run R script
Rscript --vanilla "$SCRIPT_DIR/R/jrmyscript.R" "$PAR1" "$PAR2"
EXIT_CODE=$?
printf '%s\t%s\t%s\t%s\n' \
  "$(date '+%Y-%m-%dT%H:%M:%S')" \
  "$(basename "$0")" \
  "$*" \
  "$EXIT_CODE" >> "$LOG_FILE"
exit $EXIT_CODE
